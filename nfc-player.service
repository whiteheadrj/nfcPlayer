[Unit]
Description=NFC book audio player
After=network-online.target sound.target

[Service]
ExecStart=/usr/bin/python3 %h/nfc-player/nfc_player.py
Restart=always
RestartSec=5
# Uncomment to override defaults:
# Environment=SHEET_ID=1EW7mGv9IMcwiIqwEJGDhc8e-PXXOceAWLizcIYIbi-U
# Environment=SHEET_REFRESH_SECONDS=300
# Environment=SAME_TAG_STOPS=1
# Environment=AUDIO_DEVICE=alsa/plughw:CARD=Headphones

[Install]
WantedBy=default.target
